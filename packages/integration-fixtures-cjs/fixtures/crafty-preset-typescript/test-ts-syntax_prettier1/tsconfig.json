{
  "exclude": [
    "node_modules",
    "node",
    "css",
    "etc"
  ],
  "compilerOptions": {
    "rootDir": "./js",
    "declaration": true,
    "moduleResolution": "nodenext",
    "jsx": "react",
    "module": "nodenext",
    "sourceMap": true,
    "target": "esnext",
    "lib": ["DOM", "ES2017", "DOM.Iterable", "ScriptHost"]
  }
}
